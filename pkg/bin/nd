#!/usr/bin/env zsh
set -eu -o pipefail

if [[ -v nd_verbose ]]; then
    set -x
    # TODO currently not used anymore, if the approach with `nix print-dev-env` works, remove this
    local nix_develop_args=(--debug --verbose --print-build-logs --log-format raw)
else
    local nix_develop_args=()
fi

# a flake reference
# only local flakes are allowed, eg
# - ../somewhere/here
# - ../somewhere/here#name
# - path:../somewhere/here
local _flake

# the plain folder of the flake, without any 'path:' or '#name' elements
local _folder

function ensure-flake {
    if [[ $_flake != '' ]]; then
        return
    fi

    if [[ -v nd_env ]]; then
        _flake=$nd_env
        _folder=
        if [[ $_flake != '-' ]]; then
            if [[ ! $_flake =~ '(path:)?(.*)(#.*)?' ]]; then
                echo "Cannot parse flake reference $_flake" >&2
                exit 1
            fi
            _folder=$match[2]
        fi
        return
    fi

    _flake=$(setopt extended_glob null_glob; echo (../)#flake.nix(:a:h))
    _folder=$_flake
    if [[ $_flake == '' ]]; then
        echo "No flake found at $PWD or up and no nd_env." >&2
        exit 1
    fi
}

function make {
    mkdir -p $_folder/.nd
    #
    # double --quiet doesnt warn about dirty git, but might hide other things too?
    # TODO might produce more progress?: nix develop $_flake --quiet --quiet --profile $_folder/.nd/dev $@ --command true
    echo '#!/usr/bin/env bash' > $_folder/.nd/run
    nix print-dev-env --quiet --quiet --profile $_folder/.nd/dev $_flake >> $_folder/.nd/run
    echo 'export nd_nix='$(realpath $_folder/.nd/dev) >> $_folder/.nd/run
    echo 'exec "$@"' >> $_folder/.nd/run
    chmod +x $_folder/.nd/run

    cp $_folder/flake.lock $_folder/.nd/flake.lock
}

function nd-build nd-b {
    ensure-flake

    if [[ $_flake == '-' ]]; then
        return
    fi

    if which flupq &>/dev/null && [[ -e $_folder/flake.lock ]]; then
        mkdir -p $_folder/.nd
        # TODO --offline seems to do nothing in `flake update`, it still downloads stuff and is slow
        flupq --offline --quiet --quiet --output-lock-file $_folder/.nd/flup.lock --flake $_flake
        if [[ -e $_folder/.nd/flup.lock ]]; then
            if ! diff $_folder/flake.lock $_folder/.nd/flup.lock &>/dev/null; then
                echo
                print -P -- '%F{1}%Snd: `flup` would change "flake.lock".%s%f'
            fi
            rm $_folder/.nd/flup.lock
        else
            print -P -- '%F{1}%Snd: `flup` didnt produce a lock file.%s%f'
        fi
    fi

    make
}

# TODO "quick-build", until we have a better solution for the slow flup
function nd-qbuild nd-qb {
    ensure-flake

    if [[ $_flake == '-' ]]; then
        return
    fi

    make
}

function nd-run nd-r {
    ensure-flake

    if [[ $_flake == '-' ]]; then
        exec ${@:-zsh}
    fi

    if [[ ! -e $_folder/.nd/run ]]; then
        nd-build
    fi

    if [[ -v nd ]]; then
        nd=$_folder:$nd
    else
        export nd=$_folder
    fi

    local last_build
    if [[ $OSTYPE == linux-gnu ]]; then
        last_build=$(stat --format='%Y' $_folder/.nd/dev)
    elif [[ $OSTYPE == darwin* ]]; then
        last_build=$(stat -f '%m' $_folder/.nd/dev)
    else
        echo "Unknown OSTYPE $OSTYPE." >&2
        exit 1
    fi

    if [[ $(( $(date '+%s') - $last_build > 7 * 24 * 60 * 60 )) == 1 ]]; then
        echo
        print -P -- '%F{1}%Snd: No rebuild since more than a week.%s%f'
    fi

    if [[ -e $_folder/flake.lock && -e $_folder/.nd/flake.lock ]] && ! diff $_folder/flake.lock $_folder/.nd/flake.lock &>/dev/null; then
        echo
        print -P -- '%F{1}%Snd: Profile is from a different "flake.lock".%s%f'
    fi

    # TODO --offline for faster?
    # TODO or maybe we just say we only do on demand, no automatic checks? could we keep a fork-server? but then again, the env json is not so difficult to use anyway
    #      we just need something we can source at the start? it just feels invasive this way
    # TODO nix print-dev-env and --json, could be easier? does it behave the same? is it the same content as the json file anyway?
    #      what if we change, will it fail while broken syntax?
    #      can we detect changes? or make it on-demand?
    #      add some nd_ vars in devShell to indicate if you want full or just the simple vars? its quite easy to source or parse
    # exec nix develop --offline $nix_develop_args $_folder/.nd/dev --command ${@:-zsh}

    # TODO this leaves nix out of it and should always be fast?
    # but a bit hard to say if it's messy with my own variables or anything
    # TODO hm some things dont work for zsh :/ filter, ignore? bash and record?
    #      at this point the json is easier, but not all vars from the json are actually applied
    #      eg, HOME is there, marked export, but not done by print-dev-env
    # nix print-dev-env --offline $_folder/.nd/dev > $_folder/.nd/run
    # echo 'exec "$@"' >> $_folder/.nd/run
    # TODO print-dev-env is not totally the same as nix develop, for example NIX_GCROOT is not set
    exec $_folder/.nd/run ${@:-zsh}
}

function nd-shell nd-s {
    nd-run zsh $@
}

function nd-env nd-e {
    nd-at ${nd_env:--} $@
}

function nd-tmux {
    [[ ! -v TMUX ]]
    h=${1:-$PWD}
    h=${h:a}
    cd $h
    ensure-flake
    if [[ $_flake == '-' ]]; then
        exec tmux new-session -s ${h:a:t} $@
    else
        exec tmux new-session -s ${h:a:t} -e h=$h -e nd_env=$_flake $@[2,-1]
    fi
}

function nd-at {
    _flake=$1
    _folder=
    if [[ $_flake != '-' ]]; then
        if [[ ! $_flake =~ '(path:)?(.*)(#.*)?' ]]; then
            echo "Cannot parse flake reference $_flake" >&2
            exit 1
        fi
        _folder=$match[2]
    fi
    nd-${2:-shell} $@[3,-1]
}

nd-${1:-shell} $@[2,-1]
